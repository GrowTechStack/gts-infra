aws_region = "ap-northeast-2"

# SSH 공개키 (터미널에서 실행 후 복붙)
# ssh-keygen -t rsa -b 4096 -f ~/.ssh/gts-key
# cat C:\Users\{username}\.ssh\gts-key.pub
public_key = "ssh-rsa AAAAB3NzaC1yc2E..."

# RDS MySQL 비밀번호 (8자 이상)
db_password = "your_db_password_here"

# Groq API Key (gts-infra/.env 참고)
ai_api_key = "gsk_..."

# Confluent Cloud Kafka
# 1. https://confluent.io 가입
# 2. Basic 클러스터 생성 (AWS / us-east-2)
# 3. API Keys 발급
kafka_bootstrap_servers = "pkc-xxxxx.us-east-2.aws.confluent.cloud:9092"
kafka_api_key           = "your_kafka_api_key"
kafka_api_secret        = "your_kafka_api_secret"
